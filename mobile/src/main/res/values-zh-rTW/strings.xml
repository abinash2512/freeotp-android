    <!-- Strings for the password activity. -->
    <string name="password">輸入密碼</string>
    <string name="password_confirm">確認密碼</string>
    <string name="password_info">動態密碼備份可協助您從資料遺失中復原，並輕鬆將動態密碼移轉到新裝置。
\n
\n備份會使用下方提供的密碼加密。備份安全性取決於密碼強度。
\n
\nFreeOTP 的安全模型規定，這組密碼日後無法變更。選擇密碼時請納入考量。</string>
